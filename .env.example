# Every variable sift recognizes, with its default. This file is optional —
# sift boots with zero configuration; there is no env var for LLM provider
# API keys, those are entered through the running app's Config UI page.
#
# Docker (docker-compose.yml) already sets SIFT_DB_PATH/SIFT_CONFIG_DIR to
# the mounted volume paths, so you shouldn't need this file for the Docker
# path. It's here for the non-Docker path (npm start), if you want to
# relocate the database or config directory without editing code.

# Where the SQLite database file lives.
SIFT_DB_PATH=data/sift.db

# Where config/settings.json, config/sources.json, and config/providers.json
# (the API keys you enter in-app) live.
SIFT_CONFIG_DIR=config
